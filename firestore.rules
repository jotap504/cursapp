rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function signedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }

    // Courses: Anyone can read courses, only admin can write
    match /cursos/{cursoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site Config: Anyone can read, only admin can write
    match /configuracion/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users: Users can read/write their own profile
    match /usuarios/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId); // Temporary to allow claimAdmin
    }

    
    // Purchases / Transactions (Future implementation)
    match /compras/{compraId} {
      allow read: if signedIn() && (resource.data.usuario_id == request.auth.uid);
      allow write: if false; // Only via webhook/backend
    }
  }
}
